---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy - LearnLoom" description="Read the LearnLoom Privacy Policy. We are committed to protecting your personal information and your right to privacy.">
    <main class="max-w-5xl mx-auto my-8 lg:my-12 p-8 sm:p-12 bg-white rounded-2xl shadow-xl">
        <!-- Header Section -->
        <div class="border-b-4 border-[#EA0264] pb-6 mb-10">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-3">Privacy Policy</h1>
            <p class="text-sm text-gray-500 italic">Last Updated: January 5, 2026</p>
        </div>

        <!-- Content Sections -->
        <div class="space-y-10">
            <!-- Section 1 -->
            <section class="bg-gray-50 rounded-lg p-6 border-l-4 border-[#EA0264]">
                <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
                    <span
                        class="bg-[#EA0264] text-white rounded-full w-8 h-8 flex items-center justify-center mr-3 text-lg">1</span>
                    Introduction
                </h2>
                <p class="text-gray-700 leading-relaxed text-base">
                    Welcome to LearnLoom. We are committed to protecting your personal information and your right to
                    privacy.
                    When you visit our website including any other media form, media channel, mobile website, or mobile
                    application
                    related or connected thereto (collectively, the "Site"), you trust us with your personal
                    information.
                </p>
            </section>

            <!-- Section 2 -->
            <section class="bg-gray-50 rounded-lg p-6 border-l-4 border-[#EA0264]">
                <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
                    <span
                        class="bg-[#EA0264] text-white rounded-full w-8 h-8 flex items-center justify-center mr-3 text-lg">2</span>
                    Information We Collect
                </h2>
                <p class="text-gray-700 leading-relaxed mb-4 text-base">
                    We collect personal information that you voluntarily provide to us when you register on the Site,
                    express an interest in obtaining information about us or our products and services (such as by
                    filling out
                    a form or booking a demo), or otherwise when you contact us.
                </p>
                <p class="text-gray-700 leading-relaxed mb-3 text-base">
                    The personal information that we collect depends on the context of your interactions with us and the
                    Site,
                    the choices you make, and the products and features you use. The personal information we collect may
                    include:
                </p>
                <ul class="list-none space-y-2 ml-4">
                    <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#EA0264] mr-2 mt-0.5 flex-shrink-0" fill="currentColor"
                            viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="text-gray-700">Names and Contact Data (Email, Phone Number)</span>
                    </li>
                    <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#EA0264] mr-2 mt-0.5 flex-shrink-0" fill="currentColor"
                            viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="text-gray-700">Student details provided during registration</span>
                    </li>
                </ul>
            </section>

            <!-- Section 3 -->
            <section class="bg-gray-50 rounded-lg p-6 border-l-4 border-[#EA0264]">
                <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
                    <span
                        class="bg-[#EA0264] text-white rounded-full w-8 h-8 flex items-center justify-center mr-3 text-lg">3</span>
                    Use of Information
                </h2>
                <p class="text-gray-700 leading-relaxed mb-3 text-base">
                    We use personal information collected via our Site for a variety of business purposes described
                    below:
                </p>
                <ul class="list-none space-y-2 ml-4">
                    <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#EA0264] mr-2 mt-0.5 flex-shrink-0" fill="currentColor"
                            viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="text-gray-700">To facilitate account creation and logon process</span>
                    </li>
                    <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#EA0264] mr-2 mt-0.5 flex-shrink-0" fill="currentColor"
                            viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="text-gray-700">To send you marketing and promotional communications (you can
                            opt-out at any time)</span>
                    </li>
                    <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#EA0264] mr-2 mt-0.5 flex-shrink-0" fill="currentColor"
                            viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="text-gray-700">To fulfill and manage your orders/bookings</span>
                    </li>
                </ul>
            </section>

            <!-- Section 4 -->
            <section class="bg-gray-50 rounded-lg p-6 border-l-4 border-[#EA0264]">
                <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
                    <span
                        class="bg-[#EA0264] text-white rounded-full w-8 h-8 flex items-center justify-center mr-3 text-lg">4</span>
                    Facebook Pixel and Tracking
                </h2>
                <p class="text-gray-700 leading-relaxed text-base">
                    We use Facebook Pixel and other tracking technologies to collect data about your behavior on our
                    website.
                    This data allows us to measure the effectiveness of our advertising and provide you with more
                    relevant ads.
                    The data collected is anonymous to us but is processed by Facebook and may be linked to your
                    Facebook account.
                </p>
            </section>

            <!-- Section 5 -->
            <section class="bg-pink-50 rounded-lg p-6 border-l-4 border-[#EA0264]">
                <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
                    <span
                        class="bg-[#EA0264] text-white rounded-full w-8 h-8 flex items-center justify-center mr-3 text-lg">5</span>
                    Contact Us
                </h2>
                <p class="text-gray-700 leading-relaxed mb-4 text-base">
                    If you have questions or comments about this policy, you may contact us using the information below:
                </p>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                    <p class="text-gray-900 font-semibold text-lg mb-2">LearnLoom Admin</p>
                    <p class="text-gray-700 mb-1">
                        <span class="font-medium">Email:</span>
                        <a href="mailto:admin@learnloom.com.au"
                            class="text-[#EA0264] hover:underline">admin@learnloom.com.au</a>
                    </p>
                    <p class="text-gray-700">
                        <span class="font-medium">Phone:</span>
                        <a href="tel:+61416289704" class="text-[#EA0264] hover:underline">+61 416 289 704</a>
                    </p>
                </div>
            </section>
        </div>
    </main>
</BaseLayout>
