---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us - LearnLoom" description="We believe learning should be more than just textbooks and tests — it should spark curiosity, confidence, and creativity. Learn about the LearnLoom vision and story.">
    <main class="max-w-4xl mx-auto my-8 lg:my-16 p-8 sm:p-12 bg-white/70 backdrop-blur-md rounded-3xl shadow-xl border border-slate-100/60 relative">
        <!-- Floating gradient background shapes -->
        <div class="absolute -top-12 -left-12 w-48 h-48 bg-pink-100/30 rounded-full filter blur-3xl -z-10"></div>
        <div class="absolute -bottom-12 -right-12 w-48 h-48 bg-blue-100/30 rounded-full filter blur-3xl -z-10"></div>

        <!-- Header Section -->
        <div class="text-center mb-16">
            <div class="inline-flex items-center space-x-2 bg-pink-50 border border-pink-100/60 px-4 py-1 rounded-full text-xs font-bold text-[#EA0264] mb-4">
                <span>Our Mission</span>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight leading-tight">About LearnLoom</h1>
            <p class="mt-4 text-lg md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">We believe learning should be more than just textbooks and tests — it should spark curiosity, confidence, and creativity.</p>
            <p class="mt-6 text-base md:text-lg text-slate-700 leading-relaxed max-w-3xl mx-auto">
                We are an online learning platform dedicated to helping students from Grades 1 to 10 build strong
                foundations in Math, Science, English, and Languages, while also preparing them for competitive exams
                like Math Olympiads, NAPLAN, and Selective Exams.
            </p>
        </div>

        <!-- Our Story Section -->
        <section id="story" class="mb-16">
            <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 border-b-2 border-pink-500/20 pb-3 mb-6">Our Story</h2>
            <p class="text-base md:text-lg text-slate-700 leading-relaxed mb-10">
                LearnLoom was founded with one vision — to make learning interactive, meaningful, and future-ready for
                every child.
            </p>
            
            <!-- Founder Profile Block (New-Gen Card) -->
            <div class="relative bg-white/60 p-8 rounded-3xl shadow-md border border-slate-100/60 flex flex-col md:flex-row gap-8 items-center md:items-start group hover:shadow-lg transition-all duration-300">
                <div class="flex-shrink-0 w-24 h-24 rounded-2xl bg-gradient-to-tr from-[#FF2E93] to-[#EA0264] p-0.5 shadow-md shadow-pink-500/10 flex items-center justify-center text-white font-extrabold text-3xl select-none group-hover:scale-105 transition-transform duration-300">
                    AM
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-slate-900 leading-tight">Anu Murali</h3>
                    <p class="text-sm font-semibold bg-pink-50 text-[#EA0264] border border-pink-100/60 px-3 py-0.5 rounded-full inline-block mt-2">Co-founder & Head of Academics</p>
                    <p class="mt-4 text-slate-600 leading-relaxed text-sm md:text-base">
                        Anu began her journey as an Assistant Professor and Montessori guide. Holding Cambridge and AMI
                        certifications, she blends traditional and modern methods to make every lesson engaging, creative,
                        and concept-driven so that children don’t just learn—they love learning.
                    </p>
                </div>
            </div>
        </section>

        <!-- What Makes Us Different Section -->
        <section id="what-makes-us-different" class="mb-16">
            <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 border-b-2 border-pink-500/20 pb-3 mb-8">What Makes Us Different</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Item 1 -->
                <div class="group flex items-start gap-4 p-5 rounded-2xl hover:bg-white/50 transition-colors duration-300">
                    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-pink-50 rounded-xl group-hover:bg-gradient-to-tr group-hover:from-[#FF2E93] group-hover:to-[#EA0264] group-hover:text-white transition-all duration-300">
                        <svg class="w-5 h-5 text-[#EA0264] group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none"
                            viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.311a7.5 7.5 0 01-7.5 0c-1.255 0-2.443.29-3.5.832M12 6.75a2.25 2.25 0 110-4.5 2.25 2.25 0 010 4.5zM12 18.75a2.25 2.25 0 110-4.5 2.25 2.25 0 010 4.5z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 text-lg group-hover:text-[#EA0264] transition-colors">Concept-first approach</h3>
                        <p class="text-slate-600 leading-relaxed text-sm mt-1">Every lesson starts with clarity, ensuring children truly understand, not just memorize.</p>
                    </div>
                </div>
                <!-- Item 2 -->
                <div class="group flex items-start gap-4 p-5 rounded-2xl hover:bg-white/50 transition-colors duration-300">
                    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-pink-50 rounded-xl group-hover:bg-gradient-to-tr group-hover:from-[#FF2E93] group-hover:to-[#EA0264] group-hover:text-white transition-all duration-300">
                        <svg class="w-5 h-5 text-[#EA0264] group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none"
                            viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.82m5.84-2.56a12.026 12.026 0 010 2.56m-5.84 0a12.026 12.026 0 010-2.56m-7.18 4.82a6 6 0 015.84-7.38v5.84" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 text-lg group-hover:text-[#EA0264] transition-colors">Interactive and fun</h3>
                        <p class="text-slate-600 leading-relaxed text-sm mt-1">We weave in activities, games, simulations, and real-world examples so learning sticks.</p>
                    </div>
                </div>
                <!-- Item 3 -->
                <div class="group flex items-start gap-4 p-5 rounded-2xl hover:bg-white/50 transition-colors duration-300">
                    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-pink-50 rounded-xl group-hover:bg-gradient-to-tr group-hover:from-[#FF2E93] group-hover:to-[#EA0264] group-hover:text-white transition-all duration-300">
                        <svg class="w-5 h-5 text-[#EA0264] group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none"
                            viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 text-lg group-hover:text-[#EA0264] transition-colors">Personalized guidance</h3>
                        <p class="text-slate-600 leading-relaxed text-sm mt-1">Small batches, regular feedback, and progress reviews help every child grow at their own pace.</p>
                    </div>
                </div>
                <!-- Item 4 -->
                <div class="group flex items-start gap-4 p-5 rounded-2xl hover:bg-white/50 transition-colors duration-300">
                    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-pink-50 rounded-xl group-hover:bg-gradient-to-tr group-hover:from-[#FF2E93] group-hover:to-[#EA0264] group-hover:text-white transition-all duration-300">
                        <svg class="w-5 h-5 text-[#EA0264] group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none"
                            viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 text-lg group-hover:text-[#EA0264] transition-colors">Global mindset</h3>
                        <p class="text-slate-600 leading-relaxed text-sm mt-1">From Math problem-solving to language fluency, we prepare learners for opportunities beyond borders.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dynamic Brand Summary Panel -->
        <section class="bg-gradient-to-tr from-pink-500 to-rose-600 rounded-3xl p-8 md:p-12 text-center text-white shadow-xl shadow-pink-500/10">
            <p class="text-xl md:text-2xl leading-relaxed font-extrabold mb-4">
                Our name, LearnLoom, reflects our mission — weaving together
                knowledge, skills, and creativity into a strong fabric that supports lifelong learning.
            </p>
            <p class="text-base md:text-lg text-white/90 max-w-xl mx-auto leading-relaxed">
                At LearnLoom, we’re not just teaching subjects — we’re building future-ready learners who are confident, curious, and capable of achieving their dreams.
            </p>
        </section>

        <!-- CTA Touch -->
        <section class="text-center mt-16">
            <a href="/Contactus"
                class="inline-block bg-gradient-to-r from-[#FF2E93] to-[#EA0264] text-white font-bold py-4 px-10 rounded-full shadow-lg shadow-pink-500/20 hover:shadow-xl hover:shadow-pink-500/30 hover:scale-105 active:scale-98 transition-all duration-300 transform">
                Get in Touch
            </a>
        </section>
    </main>
</BaseLayout>
