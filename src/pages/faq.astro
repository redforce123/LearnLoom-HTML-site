---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="FAQ - LearnLoom" description="Find answers to frequently asked questions about online tutoring at LearnLoom, including enrollment, teaching methods, assessments, and grade criteria.">
    <!-- Main Content Area -->
    <main class="container mx-auto px-4 py-12 flex-grow">

        <!-- FAQ Section -->
        <div class="py-12 max-w-3xl mx-auto relative">
            <!-- Background Radial Glow -->
            <div class="absolute -top-12 left-1/2 -translate-x-1/2 w-96 h-96 bg-pink-100/30 rounded-full filter blur-3xl -z-10"></div>

            <div class="text-center mb-16">
                <div class="inline-flex items-center space-x-2 bg-pink-50 border border-pink-100/60 px-4 py-1.5 rounded-full text-xs font-bold text-[#EA0264] mb-4">
                    <span>Help Center</span>
                </div>
                <h1 class="text-3xl md:text-5xl font-extrabold text-center text-slate-900 tracking-tight leading-tight">Frequently Asked Questions</h1>
                <p class="text-base md:text-lg text-slate-600 mt-3 max-w-xl mx-auto leading-relaxed">Have a question about our tutoring platform? Here are answers to the most common queries.</p>
            </div>

            <div class="space-y-4">
                <!-- FAQ Item 1 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">How to Enroll?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">Once you click the ‘Register or Enroll‘ button on our website, you fill
                            out a short form to help us understand your child’s need. Post this, an academic counsellor
                            is assigned, and a trial class may be provided. Once satisfied, the enrolment process
                            begins.</p>
                    </div>
                </div>

                <!-- FAQ Item 2 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">What are the benefits of these math classes?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">Learn Loom travels with the child parallel to their school curriculum.
                            Along with it, we prepare them to ace in their competitive exam. The experts plan the
                            curriculum well to utilise the stipulated time in a friendly way, and keeping the interest
                            alive.</p>
                    </div>
                </div>

                <!-- FAQ Item 3 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">How are these classes different from the school?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">The lesson plan will include projects beyond books within the module,
                            to ensure active learning. The teachers will be using interactive math tools to keep the
                            interest alive and make sessions more fun.</p>
                    </div>
                </div>

                <!-- FAQ Item 4 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">How are assessment and progress of the child done?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">Assignments will be given after each class to help in the formative
                            assessment. They are uploaded and evaluated by the teacher. Moreover the parent will be
                            constantly updated about the learning journey of the child.</p>
                    </div>
                </div>

                <!-- FAQ Item 5 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">What is the age criteria of the child?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">Currently, we are providing lessons for grade 1-10.</p>
                    </div>
                </div>

                <!-- FAQ Item 6 -->
                <div class="bg-white/70 backdrop-blur-md rounded-3xl shadow-md border border-slate-100 hover:border-pink-200/50 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 overflow-hidden">
                    <button
                        class="faq-toggle w-full text-left p-6 md:p-8 flex justify-between items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#EA0264]"
                        aria-expanded="false">
                        <h3 class="font-extrabold text-lg text-slate-900 leading-tight">How to take these classes?</h3>
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 transition-colors duration-300">
                            <svg class="w-4 h-4 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </button>
                    <div class="faq-content px-6 md:px-8 pb-6 md:pb-8 hidden border-t border-slate-50/50 pt-4">
                        <p class="text-slate-600 leading-relaxed text-sm md:text-base">Desktop, mic and internet connectivity.</p>
                    </div>
                </div>
            </div>
        </div>

    </main>
</BaseLayout>

<script>
    // Accordion Toggle Logic (Updated for New Gen styles)
    const faqToggles = document.querySelectorAll('.faq-toggle');

    faqToggles.forEach(toggle => {
        toggle.addEventListener('click', () => {
            const content = toggle.nextElementSibling;
            const iconContainer = toggle.querySelector('.rounded-full');
            const icon = toggle.querySelector('svg');

            if (content && icon && iconContainer) {
                const expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', String(!expanded));

                // Toggle visibility
                content.classList.toggle('hidden');

                // Rotate toggle icon
                icon.classList.toggle('rotate-180');

                // Toggle dynamic border/background active state on trigger wrapper
                if (!expanded) {
                    iconContainer.classList.remove('bg-slate-100', 'text-slate-500');
                    iconContainer.classList.add('bg-pink-500', 'text-white');
                } else {
                    iconContainer.classList.remove('bg-pink-500', 'text-white');
                    iconContainer.classList.add('bg-slate-100', 'text-slate-500');
                }
            }
        });
    });
</script>
