---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Login - LearnLoom" description="Access your LearnLoom student or parent portal here to view lessons, progress, and assignments.">
    <!-- Main Content Area -->
    <main class="container mx-auto px-4 py-12 flex-grow flex flex-col items-center justify-center">
        <!-- Page Title -->
        <div class="text-center mb-8">
            <h1 class="text-3xl md:text-4xl font-bold text-black">Student & Parent Login</h1>
            <p class="text-lg text-gray-700 mt-2">Access your LearnLoom portal below.</p>
        </div>

        <!-- TutorBird Login Widget -->
        <div class="w-full max-w-2xl bg-white rounded-xl shadow-lg p-4 md:p-6 min-h-[600px]">
            <script is:inline
                src="https://app.tutorbird.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9GYnNKUSIsIldlYnNpdGVJRCI6Indic196OFBKaiIsIldlYnNpdGVCbG9ja0lEIjoid2JiX3hsYkNKVyJ9"></script>
        </div>
    </main>
</BaseLayout>
