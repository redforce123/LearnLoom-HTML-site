---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="LearnLoom - Global STEAM Education Program" description="Personalized 1-on-1 STEAM education program for students globally. LearnLoom helps students excel in Maths, English, and Science. Book your free demo!">
    <!-- Main Content Area -->
    <main class="container mx-auto px-4 py-12 flex-grow">

        <!-- Hero Section -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-16 text-center md:text-left py-12">
            <!-- Text and CTA section -->
            <div class="md:w-1/2 flex flex-col items-center md:items-start">
                <!-- Premium Next-Gen Trust Badge -->
                <div class="inline-flex items-center space-x-2 bg-pink-50 border border-pink-100/60 px-4 py-1.5 rounded-full text-xs font-bold text-[#EA0264] mb-6 shadow-sm shadow-pink-500/5 hover:bg-pink-100/40 transition-colors duration-300">
                    <span class="flex h-2 w-2 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#EA0264]"></span>
                    </span>
                    <span>1-on-1 Global STEAM Education Program</span>
                </div>

                <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tight text-slate-900 mb-6 leading-[1.1]">
                    A Loom of Ideas,<br>
                    <span class="bg-gradient-to-r from-[#FF2E93] via-[#EA0264] to-[#A80148] bg-clip-text text-transparent">A World of Learning.</span>
                </h1>
                <p class="text-lg text-slate-600 mb-8 max-w-xl mx-auto md:mx-0 leading-relaxed">
                    Personalized 1-on-1 STEAM education programs to build confidence and excel in your studies. We make complex concepts simple, intuitive, and engaging for students globally.
                </p>
                <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
                    <a href="/BookDemo"
                        class="w-full sm:w-auto inline-flex items-center justify-center bg-gradient-to-r from-[#FF2E93] to-[#EA0264] text-white font-bold py-4 px-10 rounded-full shadow-lg shadow-pink-500/20 hover:shadow-xl hover:shadow-pink-500/30 hover:scale-105 active:scale-98 transition-all duration-300 transform">
                        Book a Free Demo
                    </a>
                </div>

                <!-- News Ticker (Integrated) -->
                <div class="mt-10 relative w-full flex items-center justify-center md:justify-start">
                    <div class="relative w-full min-h-[4.5rem] md:min-h-[3rem] bg-white/40 border border-white/50 backdrop-blur-sm px-4 py-2.5 rounded-2xl max-w-lg shadow-sm">
                        <span id="news-typewriter"
                            class="typewriter-text font-bold text-sm md:text-base block md:inline-block leading-normal"
                            aria-live="polite"></span>
                        <!-- Hidden container for SEO -->
                        <div id="seo-news-content" class="sr-only"></div>
                    </div>
                </div>
            </div>

            <!-- Image section with radial glow overlay -->
            <div class="md:w-1/2 relative group">
                <div class="absolute inset-0 bg-gradient-to-tr from-pink-400 to-rose-400 rounded-3xl blur-3xl opacity-15 group-hover:opacity-20 transition-opacity duration-500"></div>
                <div class="relative border border-white/40 p-2.5 bg-white/20 backdrop-blur-sm rounded-3xl shadow-2xl shadow-slate-900/10 overflow-hidden">
                    <img src="/Images/student.png"
                        alt="A young student smiling while engaged in a hands-on online STEAM education session with LearnLoom globally."
                        class="w-full h-auto object-cover rounded-2xl group-hover:scale-[1.02] transition-transform duration-500" width="600" height="400">
                </div>
            </div>
        </div>

        <!-- Tabbed Interface Section -->
        <div class="py-16 mt-12 relative">
            <!-- Background Blob -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-pink-100/20 rounded-full filter blur-3xl -z-10"></div>

            <!-- Tab Navigation (Sleek SaaS Track) -->
            <div class="mb-12 overflow-x-auto custom-scrollbar pb-2 max-w-full">
                <div class="flex space-x-2 bg-slate-200/40 p-1.5 rounded-2xl min-w-max border border-slate-200/30 max-w-2xl mx-auto">
                    <button data-tab-target="#services"
                        class="tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10">
                        What We Offer
                    </button>
                    <button data-tab-target="#enrollment"
                        class="tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-slate-600 hover:text-slate-900 hover:bg-white/60">
                        Enrollment
                    </button>
                    <button data-tab-target="#learnloom-method"
                        class="tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-slate-600 hover:text-slate-900 hover:bg-white/60">
                        LearnLoom Method
                    </button>
                    <button data-tab-target="#testimonials"
                        class="tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-slate-600 hover:text-slate-900 hover:bg-white/60">
                        Testimonials
                    </button>
                </div>
            </div>

            <!-- Tab Content -->
            <div class="min-h-[500px] transition-all duration-300">
                <!-- Services Panel (Visible by default) -->
                <div id="services" class="tab-panel">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight">Our Core Subjects</h2>
                        <p class="text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">From foundational learning to specialized exam preparation, we provide the tools for success.</p>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                        <!-- Maths Card -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:shadow-pink-500/5 hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col items-center text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 -z-10"></div>
                            <div class="mx-auto flex items-center justify-center h-32 w-32 rounded-2xl bg-gradient-to-br from-pink-50 to-rose-50 p-1 mb-6 border border-slate-100/50 group-hover:scale-105 transition-transform duration-500 overflow-hidden">
                                <img src="/Images/Maths.jpg"
                                    alt="A vibrant image representing mathematics tutoring for NAPLAN and selective entry exams."
                                    class="w-full h-full object-cover rounded-xl" width="128" height="128" loading="lazy">
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-2">Maths</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">NAPLAN, Selective Entry, and High School Calculus.</p>
                        </div>
                        <!-- English Card -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:shadow-pink-500/5 hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col items-center text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 -z-10"></div>
                            <div class="mx-auto flex items-center justify-center h-32 w-32 rounded-2xl bg-gradient-to-br from-pink-50 to-rose-50 p-1 mb-6 border border-slate-100/50 group-hover:scale-105 transition-transform duration-500 overflow-hidden">
                                <img src="/Images/English.jpg"
                                    alt="An open book representing LearnLoom's English STEAM program for reading comprehension and essay writing globally."
                                    class="w-full h-full object-cover rounded-xl" width="128" height="128" loading="lazy">
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-2">English</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">Essay Writing, Reading Comprehension, and Grammar.</p>
                        </div>
                        <!-- Science Card -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:shadow-pink-500/5 hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col items-center text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 -z-10"></div>
                            <div class="mx-auto flex items-center justify-center h-32 w-32 rounded-2xl bg-gradient-to-br from-pink-50 to-rose-50 p-1 mb-6 border border-slate-100/50 group-hover:scale-105 transition-transform duration-500 overflow-hidden">
                                <img src="/Images/Science.jpg"
                                    alt="A microscope and beakers symbolizing hands-on science STEAM classes for students globally."
                                    class="w-full h-full object-cover rounded-xl" width="128" height="128" loading="lazy">
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-2">Science</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">Covering Physics, Chemistry, and Biology concepts.</p>
                        </div>
                        <!-- Art Classes Card -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:shadow-pink-500/5 hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col items-center text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 -z-10"></div>
                            <div class="mx-auto flex items-center justify-center h-32 w-32 rounded-2xl bg-gradient-to-br from-pink-50 to-rose-50 p-1 mb-6 border border-slate-100/50 group-hover:scale-105 transition-transform duration-500 overflow-hidden">
                                <img src="/Images/Art_classes.png"
                                    alt="Vibrant art supplies representing LearnLoom's creative art classes for children."
                                    class="w-full h-full object-cover rounded-xl" width="128" height="128" loading="lazy">
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-2">Art Classes</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">Creative drawing, painting, and craft workshops.</p>
                        </div>
                    </div>

                    <!-- Subscribe Button -->
                    <div class="text-center mt-16">
                        <button id="subscribe-button"
                            class="inline-block bg-gradient-to-r from-[#FF2E93] to-[#EA0264] text-white font-bold py-3.5 px-8 rounded-full shadow-md shadow-pink-500/10 hover:shadow-lg hover:shadow-pink-500/20 hover:scale-[1.03] transition-all duration-300">Subscribe
                            to our Newsletter</button>
                    </div>
                </div>

                <!-- Enrollment Process Panel (Hidden by default) -->
                <div id="enrollment" class="tab-panel hidden">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight">Step-by-Step Enrollment</h2>
                        <p class="text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">Follow our simple four-step process to get your child started on their learning journey.</p>
                    </div>

                    <!-- Steps Container with dotted connection line -->
                    <div class="relative mt-16 flex flex-col lg:flex-row items-center lg:items-start justify-center gap-y-12 lg:gap-x-6">
                        <!-- Horizontal dashed connection line for desktop -->
                        <div class="hidden lg:block absolute top-10 left-[12%] right-[12%] h-0.5 border-t-2 border-dashed border-slate-200 -z-10"></div>

                        <!-- Step 1 -->
                        <div class="flex-1 flex flex-col items-center text-center max-w-sm group">
                            <div class="flex items-center justify-center w-20 h-20 bg-white border border-slate-100 rounded-full text-slate-900 text-3xl font-extrabold mb-5 shadow-lg shadow-slate-100/50 group-hover:scale-105 group-hover:border-pink-200 group-hover:text-[#EA0264] transition-all duration-300">
                                1</div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">Book a Demo</h3>
                            <p class="text-slate-600 text-sm px-4 leading-relaxed">Navigate to the 'Book Demo' section and fill in the form. This helps us tailor the live demonstration to your child's needs.</p>
                        </div>

                        <!-- Step 2 -->
                        <div class="flex-1 flex flex-col items-center text-center max-w-sm group">
                            <div class="flex items-center justify-center w-20 h-20 bg-white border border-slate-100 rounded-full text-slate-900 text-3xl font-extrabold mb-5 shadow-lg shadow-slate-100/50 group-hover:scale-105 group-hover:border-pink-200 group-hover:text-[#EA0264] transition-all duration-300">
                                2</div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">Attend the Demo</h3>
                            <p class="text-slate-600 text-sm px-4 leading-relaxed">Join the scheduled session to experience our interactive teaching style and see how our curriculum works firsthand.</p>
                        </div>

                        <!-- Step 3 -->
                        <div class="flex-1 flex flex-col items-center text-center max-w-sm group">
                            <div class="flex items-center justify-center w-20 h-20 bg-white border border-slate-100 rounded-full text-slate-900 text-3xl font-extrabold mb-5 shadow-lg shadow-slate-100/50 group-hover:scale-105 group-hover:border-pink-200 group-hover:text-[#EA0264] transition-all duration-300">
                                3</div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">Meet a Coordinator</h3>
                            <p class="text-slate-600 text-sm px-4 leading-relaxed">After the demo, a coordinator will recommend classes and discuss payment plans based on the student's performance.</p>
                        </div>

                        <!-- Step 4 -->
                        <div class="flex-1 flex flex-col items-center text-center max-w-sm group">
                            <div class="flex items-center justify-center w-20 h-20 bg-white border border-slate-100 rounded-full text-slate-900 text-3xl font-extrabold mb-5 shadow-lg shadow-slate-100/50 group-hover:scale-105 group-hover:border-pink-200 group-hover:text-[#EA0264] transition-all duration-300">
                                4</div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">Finalize Enrollment</h3>
                            <p class="text-slate-600 text-sm px-4 leading-relaxed">Once you're satisfied with the plan, we'll complete the enrollment, and the student can officially begin their classes.</p>
                        </div>
                    </div>
                </div>

                <!-- LearnLoom Method Panel (Hidden by default) -->
                <div id="learnloom-method" class="tab-panel hidden">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight">The Three-C Approach</h2>
                        <p class="text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">At Learn<span class="text-[#EA0264] font-semibold">Loom</span>, we use the "Three Cs" to guide our teaching and help students succeed.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <!-- Concept Clarity -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-500 text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
                            <h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-[#EA0264] transition-colors duration-300">Concept Clarity</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">We visualize and connect new ideas to a child's everyday life, ensuring they understand concepts easily, deeply, and permanently.</p>
                        </div>
                        <!-- Confidence First -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-500 text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
                            <h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-[#EA0264] transition-colors duration-300">Confidence First</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">We provide consistent encouragement and celebrate every success, big or small, to build a strong sense of self-belief in every student.</p>
                        </div>
                        <!-- Creative Thinking -->
                        <div class="group relative bg-white/70 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-500 text-center">
                            <div class="absolute inset-0 bg-gradient-to-tr from-pink-50/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
                            <h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-[#EA0264] transition-colors duration-300">Creative Thinking</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">We encourage kids to think outside the box and solve problems in new ways. Our goal isn't just to teach them, but to inspire them to think creatively.</p>
                        </div>
                    </div>
                </div>

                <!-- Testimonials Panel (Hidden by default) -->
                <div id="testimonials" class="tab-panel hidden">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight">What Our Students Say</h2>
                        <p class="text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">Real stories from students who have grown with us.</p>
                    </div>
                    <div class="grid gap-8 grid-cols-1 lg:grid-cols-3 text-left">
                        <!-- Testimonial 1 -->
                        <div class="p-8 bg-white/70 backdrop-blur-md rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all duration-500 relative flex flex-col justify-between">
                            <span class="absolute top-6 right-8 text-6xl text-pink-500/10 font-serif leading-none select-none">“</span>
                            <p class="text-slate-600 italic text-base leading-relaxed z-10">"The teachers made learning fun, so I am able to prepare for competitive exams. They have a vast collection of old question papers which helped me get a good score."</p>
                            <p class="mt-6 font-bold text-slate-800 text-sm border-t border-slate-100 pt-4">- Dhruv, Grade 7</p>
                        </div>
                        <!-- Testimonial 2 -->
                        <div class="p-8 bg-white/70 backdrop-blur-md rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all duration-500 relative flex flex-col justify-between">
                            <span class="absolute top-6 right-8 text-6xl text-pink-500/10 font-serif leading-none select-none">“</span>
                            <p class="text-slate-600 italic text-base leading-relaxed z-10">"English learning is fun! I was able to think outside the box and improve my vocabulary."</p>
                            <p class="mt-6 font-bold text-slate-800 text-sm border-t border-slate-100 pt-4">- Ivanka, Grade 2</p>
                        </div>
                        <!-- Testimonial 3 -->
                        <div class="p-8 bg-white/70 backdrop-blur-md rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all duration-500 relative flex flex-col justify-between">
                            <span class="absolute top-6 right-8 text-6xl text-pink-500/10 font-serif leading-none select-none">“</span>
                            <p class="text-slate-600 italic text-base leading-relaxed z-10">"The teachers had all the books from what is taught in school. They gave me games to play and helped me choose videos to watch, which made things easy to understand."</p>
                            <p class="mt-6 font-bold text-slate-800 text-sm border-t border-slate-100 pt-4">- Raphael, Grade 3</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Form Modal -->
    <div id="form-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-3xl h-full max-h-[90vh] flex flex-col overflow-hidden border border-slate-100">
            <div class="flex justify-between items-center p-6 border-b border-slate-100">
                <h3 class="text-xl font-bold text-slate-900">Register for Workshop</h3>
                <button id="close-modal-button"
                    class="text-slate-400 hover:text-slate-700 text-2xl font-bold leading-none p-1 transition-colors" aria-label="Close modal">&times;</button>
            </div>
            <div class="p-2 flex-grow">
                <iframe id="form-iframe" class="w-full h-full border-0" src="" title="Registration Form">
                    Loading…
                </iframe>
            </div>
        </div>
    </div>

    <!-- Subscription Modal with Fillout Embed -->
    <div id="subscription-modal"
        class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-3xl h-full max-h-[90vh] flex flex-col overflow-hidden border border-slate-100">
            <div class="flex justify-between items-center p-6 border-b border-slate-100">
                <h3 class="text-xl font-bold text-slate-900">Subscribe to LearnLoom</h3>
                <button id="close-subscription-modal"
                    class="text-slate-400 hover:text-slate-700 text-2xl font-bold leading-none p-1 transition-colors" aria-label="Close modal">&times;</button>
            </div>
            <div class="p-4 flex-grow overflow-auto">
                <div style="width:100%;height:500px;" data-fillout-id="i9Uv284VDgus" data-fillout-embed-type="standard"
                    data-fillout-inherit-parameters data-fillout-dynamic-resize></div>
            </div>
        </div>
    </div>

    <!-- Fillout Form Script -->
    <script is:inline src="https://server.fillout.com/embed/v1/"></script>

    <!-- Client-side Interactive Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Tab Switching Logic (Updated with Next-Gen classes)
            const workshopTabButtons = document.querySelectorAll('.tab-button');
            const workshopTabPanels = document.querySelectorAll('.tab-panel');

            if (workshopTabButtons.length > 0) {
                workshopTabButtons.forEach(button => {
                    button.addEventListener('click', () => {
                        // Deactivate all buttons
                        workshopTabButtons.forEach(btn => {
                            btn.className = "tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-slate-600 hover:text-slate-900 hover:bg-white/60";
                        });
                        // Activate the clicked button
                        button.className = "tab-button whitespace-nowrap py-3 px-6 text-sm font-bold rounded-xl transition-all duration-300 text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10";

                        // Hide all panels
                        workshopTabPanels.forEach(panel => panel.classList.add('hidden'));
                        // Show the target panel
                        const targetPanel = document.querySelector((button as HTMLElement).dataset.tabTarget || '');
                        if (targetPanel) targetPanel.classList.remove('hidden');
                    });
                });
            }

            // Workshop Registration Modal Logic
            const modal = document.getElementById('form-modal');
            const closeModalButton = document.getElementById('close-modal-button');
            const formIframe = document.getElementById('form-iframe') as HTMLIFrameElement;
            const registerButtons = document.querySelectorAll('.register-modal-button');

            if (registerButtons.length > 0) {
                registerButtons.forEach(button => {
                    button.addEventListener('click', () => {
                        const formUrl = (button as HTMLElement).dataset.formUrl;
                        if (formUrl && formIframe && modal) {
                            formIframe.src = formUrl;
                            modal.classList.remove('hidden');
                            modal.classList.add('flex');
                        }
                    });
                });
            }

            const closeModal = () => {
                if (modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    if (formIframe) formIframe.src = '';
                }
            };

            if (closeModalButton) {
                closeModalButton.addEventListener('click', closeModal);
            }

            // Subscription Modal Logic
            const subscriptionModal = document.getElementById('subscription-modal');
            const subscribeButton = document.getElementById('subscribe-button');
            const closeSubscriptionModal = document.getElementById('close-subscription-modal');

            if (subscribeButton && subscriptionModal) {
                subscribeButton.addEventListener('click', () => {
                    subscriptionModal.classList.remove('hidden');
                    subscriptionModal.classList.add('flex');
                });
            }

            if (closeSubscriptionModal && subscriptionModal) {
                closeSubscriptionModal.addEventListener('click', () => {
                    subscriptionModal.classList.add('hidden');
                    subscriptionModal.classList.remove('flex');
                });
            }

            // Typewriter News Ticker Logic
            const newsContainer = document.getElementById('news-typewriter');
            let newsItems: string[] = [];
            let currentNewsIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            const typeSpeed = 50;
            const deleteSpeed = 30;
            const holdTime = 2000;

            fetch('/news.json')
                .then(response => response.json())
                .then(data => {
                    newsItems = data.map((item: any) => item.text);

                    // SEO: Populate hidden container
                    const seoContainer = document.getElementById('seo-news-content');
                    if (seoContainer) {
                        seoContainer.textContent = newsItems.join(' | ');
                    }

                    if (newsItems.length > 0 && newsContainer) {
                        typeWriter();
                    }
                })
                .catch(error => console.error('Error fetching news:', error));

            function typeWriter() {
                if (!newsContainer) return;
                const currentText = newsItems[currentNewsIndex];

                if (isDeleting) {
                    newsContainer.textContent = currentText.substring(0, charIndex - 1);
                    charIndex--;
                } else {
                    newsContainer.textContent = currentText.substring(0, charIndex + 1);
                    charIndex++;
                }

                let nextSpeed = typeSpeed;

                if (!isDeleting && charIndex === currentText.length) {
                    isDeleting = true;
                    nextSpeed = holdTime;
                } else if (isDeleting && charIndex === 0) {
                    isDeleting = false;
                    currentNewsIndex = (currentNewsIndex + 1) % newsItems.length;
                    nextSpeed = 500;
                } else if (isDeleting) {
                    nextSpeed = deleteSpeed;
                }

                setTimeout(typeWriter, nextSpeed);
            }
        });
    </script>
</BaseLayout>
