---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book Your Free Demo - LearnLoom" description="Take the first step towards academic success. Book your free online tutoring live demo with LearnLoom and find a time that works for you.">
    <!-- Main Content Area -->
    <main class="container mx-auto px-4 py-12 flex-grow flex flex-col items-center justify-center">

        <!-- Page Title -->
        <div class="text-center mb-8">
            <h1 class="text-3xl md:text-4xl font-bold text-black">Book Your Free Demo</h1>
            <p class="text-lg text-gray-700 mt-2">Take the first step towards academic success. Find a time that works
                for you below.</p>
        </div>

        <!-- TutorBird Booking Widget -->
        <div class="w-full max-w-4xl bg-white rounded-xl shadow-lg p-4 md:p-6 min-h-[600px]">
            <!-- The widget script will inject the booking form here -->
            <script is:inline
                src="https://app.tutorbird.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9GYnNKUSIsIldlYnNpdGVJRCI6Indic196OFBKaiIsIldlYnNpdGVCbG9ja0lEIjoid2JiX0ZMbXZKQyJ9"></script>
        </div>

    </main>
</BaseLayout>
