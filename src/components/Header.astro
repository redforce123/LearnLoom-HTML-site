---
import logoImg from '../../public/Images/LearnLoom_Logo.png';

const pathname = Astro.url.pathname;

const isHome = pathname === '/' || pathname === '/index.html' || pathname === '/index';
const isAbout = pathname.includes('/AboutUs');
const isWorkshop = pathname.includes('/workshop');
const isFaq = pathname.includes('/faq');
const isContact = pathname.includes('/Contactus');
const isLogin = pathname.includes('/login');
---

<header class="bg-white/75 backdrop-blur-md border-b border-slate-200/40 sticky top-0 z-50 transition-all duration-300">
    <nav class="container mx-auto px-4 py-2.5 flex items-center justify-between">
        <!-- Logo/Site Title -->
        <a href="/" class="flex items-center space-x-3 group">
            <div class="h-11 w-11 rounded-xl bg-gradient-to-tr from-[#FF2E93] to-[#EA0264] p-0.5 shadow-md shadow-pink-500/10 group-hover:scale-105 transition-transform duration-300 flex items-center justify-center">
                <img src={logoImg.src} alt="LearnLoom Logo" class="h-10 w-auto object-contain bg-white rounded-[10px] p-1" height="40" width="40">
            </div>
            <span class="text-2xl font-extrabold tracking-tight text-slate-900">Learn<span class="bg-gradient-to-r from-[#FF2E93] to-[#EA0264] bg-clip-text text-transparent">Loom</span></span>
        </a>

        <!-- Main Navigation Links (New Gen Pills) -->
        <div class="hidden md:flex items-center space-x-1.5 bg-slate-100/50 p-1.5 rounded-full border border-slate-200/20">
            <a href="/" class={`text-sm font-semibold px-4 py-1.5 rounded-full transition-all duration-300 ${isHome ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10' : 'text-slate-600 hover:text-slate-900 hover:bg-white/60'}`}>Home</a>
            <a href="/AboutUs" class={`text-sm font-semibold px-4 py-1.5 rounded-full transition-all duration-300 ${isAbout ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10' : 'text-slate-600 hover:text-slate-900 hover:bg-white/60'}`}>About Us</a>
            <a href="/workshop" class={`text-sm font-semibold px-4 py-1.5 rounded-full transition-all duration-300 ${isWorkshop ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10' : 'text-slate-600 hover:text-slate-900 hover:bg-white/60'}`}>Workshop</a>
            <a href="/faq" class={`text-sm font-semibold px-4 py-1.5 rounded-full transition-all duration-300 ${isFaq ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10' : 'text-slate-600 hover:text-slate-900 hover:bg-white/60'}`}>FAQ</a>
            <a href="/Contactus" class={`text-sm font-semibold px-4 py-1.5 rounded-full transition-all duration-300 ${isContact ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264] shadow-md shadow-pink-500/10' : 'text-slate-600 hover:text-slate-900 hover:bg-white/60'}`}>Contact Us</a>
        </div>

        <!-- Action Buttons (Login, Book Demo) -->
        <div class="hidden md:flex items-center space-x-4">
            <a href="/login" class={`text-sm font-semibold transition-colors duration-300 ${isLogin ? 'text-[#EA0264]' : 'text-slate-600 hover:text-[#EA0264]'}`}>Login</a>
            <a href="/BookDemo" class="bg-gradient-to-r from-[#FF2E93] to-[#EA0264] text-white text-sm font-bold py-2.5 px-6 rounded-full shadow-md shadow-pink-500/10 hover:shadow-lg hover:shadow-pink-500/20 hover:scale-[1.03] active:scale-[0.98] transition-all duration-300">Book Demo</a>
        </div>

        <!-- Mobile menu button - hidden on desktop -->
        <button id="mobile-menu-button" class="md:hidden p-2 rounded-xl bg-slate-100 hover:bg-slate-200/70 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[#EA0264]" aria-label="Toggle menu">
            <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden bg-white/95 border-b border-slate-100 backdrop-blur-lg">
        <div class="px-4 pt-2 pb-6 space-y-1.5">
            <a href="/" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isHome ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>Home</a>
            <a href="/AboutUs" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isAbout ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>About Us</a>
            <a href="/workshop" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isWorkshop ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>Workshop</a>
            <a href="/faq" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isFaq ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>FAQ</a>
            <a href="/Contactus" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isContact ? 'text-white bg-gradient-to-r from-[#FF2E93] to-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>Contact Us</a>
            <hr class="my-3 border-slate-100">
            <a href="/login" class={`block py-2.5 px-4 text-base font-semibold rounded-xl transition-all duration-300 ${isLogin ? 'text-[#EA0264]' : 'text-slate-700 hover:bg-slate-100/70'}`}>Login</a>
            <a href="/BookDemo" class="block mt-3 bg-gradient-to-r from-[#FF2E93] to-[#EA0264] text-white text-center font-bold py-3 px-6 rounded-xl shadow-md shadow-pink-500/10 hover:shadow-lg transition-all duration-300">Book Demo</a>
        </div>
    </div>
</header>

<script>
  // Mobile navigation menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
